# =============================================================================
# REQUIRED FOR COMPOSE INTERPOLATION (${VAR} in docker-compose.yml)
# These are read by docker-compose.yml whenever Compose parses the spec
# (docker compose config/build/up/etc). Set before running any compose command.
# =============================================================================
DB_USER=safenest
DB_PASSWORD=CHANGE_ME_set_before_running
DB_NAME=safenest_db
REDIS_PASSWORD=CHANGE_ME_set_before_running

# =============================================================================
# LEGACY VALUES (used by non-docker local workflows)
# These are NOT used when running via docker-compose up — Compose computes
# DATABASE_URL and REDIS_URL from the variables above. Kept for developers
# running the app directly with `pnpm dev` outside of docker-compose.
# =============================================================================
# Environment Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://safenest:CHANGE_ME_set_before_running@localhost:5432/safenest_db
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
REFRESH_TOKEN_SECRET=your-refresh-token-secret
SESSION_DURATION=7d

# Stripe (You have this)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# Mock Services (Replace with real keys later)
CHECKR_API_KEY=mock_checkr_development
JUMIO_API_TOKEN=mock_jumio_development
TWILIO_ACCOUNT_SID=mock_twilio_development
TWILIO_AUTH_TOKEN=mock_twilio_development
PLAID_CLIENT_ID=mock_plaid_development

# AWS (Optional initially)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=safenest-documents
S3_REGION=us-east-1

# External APIs
GOOGLE_MAPS_API_KEY=your-maps-key
GREATSCHOOLS_API_KEY=your-schools-key

# Security
ENCRYPTION_KEY=32-character-encryption-key-here
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100