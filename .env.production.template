# CoNest Production Environment Variables Template
# Copy this file to .env and fill in all values before deployment
#
# IMPORTANT: Never commit .env files with real values to version control
# All values marked with [REQUIRED] must be set before starting the application
#
# Generated: 2025-01-12
# Sprint: Week 1 - External Services Live

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# [REQUIRED] Must be 'production' for production deployments
NODE_ENV=production

# [REQUIRED] Must be 'production' - enforces all security validations
SECURITY_MODE=production

# Server port (default: 3000)
PORT=3000

# [REQUIRED] Public API URL (used for webhook callbacks)
API_URL=https://api.yourdomain.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# [REQUIRED] PostgreSQL database host
DB_HOST=your-rds-endpoint.amazonaws.com

# PostgreSQL port (default: 5432)
DB_PORT=5432

# [REQUIRED] Database name
DB_NAME=conest_production

# [REQUIRED] Database user
DB_USER=conest_admin

# [REQUIRED] Database password - use strong, unique password
DB_PASSWORD=your_secure_database_password

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# [REQUIRED] Redis host
REDIS_HOST=your-redis-endpoint.amazonaws.com

# Redis port (default: 6379)
REDIS_PORT=6379

# [REQUIRED] Redis password
REDIS_PASSWORD=your_secure_redis_password

# =============================================================================
# JWT CONFIGURATION
# =============================================================================

# [REQUIRED] JWT signing secret - minimum 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_minimum_32_characters

# [REQUIRED] JWT refresh token secret - minimum 32 characters
# Generate with: openssl rand -base64 32
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_32_characters

# Token expiration (defaults shown)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# STRIPE CONFIGURATION
# =============================================================================

# [REQUIRED] Stripe live secret key (must start with sk_live_)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# [REQUIRED] Stripe publishable key (must start with pk_live_)
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# [REQUIRED] Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# TELNYX PHONE VERIFICATION
# =============================================================================

# [REQUIRED] Telnyx API key
# Get from: https://portal.telnyx.com/app/auth/v2/api-keys
TELNYX_API_KEY=KEY_your_telnyx_api_key

# [REQUIRED] Telnyx Verify Profile ID
# Create at: https://portal.telnyx.com/app/verify/profiles
TELNYX_VERIFY_PROFILE_ID=your_verify_profile_id

# Telnyx API base URL (default shown)
TELNYX_BASE_URL=https://api.telnyx.com/v2

# =============================================================================
# VERIFF ID VERIFICATION
# =============================================================================

# [REQUIRED] Set to 'veriff' for production
ID_PROVIDER=veriff

# [REQUIRED] Veriff API key
# Get from: https://station.veriff.com/
VERIFF_API_KEY=your_veriff_api_key

# [REQUIRED] Veriff API secret (for webhook signature verification)
VERIFF_API_SECRET=your_veriff_api_secret

# Veriff API base URL (default shown)
VERIFF_BASE_URL=https://stationapi.veriff.com

# =============================================================================
# CERTN BACKGROUND CHECK
# =============================================================================

# [REQUIRED] Set to 'certn' for production
BG_CHECK_PROVIDER=certn

# [REQUIRED] Certn API key
# Get from: https://app.certn.co/
CERTN_API_KEY=your_certn_api_key

# Certn API base URL (default shown)
CERTN_BASE_URL=https://api.certn.co/v1

# =============================================================================
# AWS S3 CONFIGURATION
# =============================================================================

# [REQUIRED] AWS access key ID
AWS_ACCESS_KEY_ID=your_aws_access_key_id

# [REQUIRED] AWS secret access key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS region (default: us-east-1)
AWS_REGION=us-east-1

# [REQUIRED] S3 bucket name for file storage
AWS_S3_BUCKET=conest-production

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Bcrypt rounds for password hashing (default: 12)
BCRYPT_ROUNDS=12

# Rate limiting window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# [REQUIRED] Encryption master key for message encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=your_base64_encoded_32_byte_key

# =============================================================================
# CORS & LOGGING
# =============================================================================

# [REQUIRED] Allowed CORS origin(s)
CORS_ORIGIN=https://app.yourdomain.com

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================================================
# SECURITY FEATURES (all enabled by default in production)
# =============================================================================

# Rate limiting (required in production)
ENABLE_RATE_LIMITING=true

# JWT validation (required in production)
ENABLE_JWT_VALIDATION=true

# Message encryption (required in production)
ENABLE_ENCRYPTION=true

# Verification checks (required in production)
ENABLE_VERIFICATION_CHECKS=true

# Payment validation (required in production)
ENABLE_PAYMENT_VALIDATION=true

# =============================================================================
# VERIFICATION SETTINGS
# =============================================================================

# Grace period for verification expiration (default: 7 days)
VERIFICATION_GRACE_PERIOD_DAYS=7

# Admin review SLA in hours (default: 48)
ADMIN_REVIEW_SLA_HOURS=48

# =============================================================================
# OPTIONAL: MONITORING & ALERTS
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# Security log webhook URL
# SECURITY_LOG_WEBHOOK_URL=https://your-webhook-url

# Enable security alerts
# ENABLE_SECURITY_ALERTS=true

# =============================================================================
# QUICK SETUP COMMANDS
# =============================================================================
#
# Generate JWT_SECRET:
#   openssl rand -base64 32
#
# Generate JWT_REFRESH_SECRET:
#   openssl rand -base64 32
#
# Generate ENCRYPTION_MASTER_KEY:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Validate environment before deployment:
#   NODE_ENV=production npm run validate-env
#
# =============================================================================
