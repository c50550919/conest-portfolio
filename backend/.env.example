# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=safenest
DB_USER=safenest_user
DB_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Configuration (Test Mode) - Payment-First Architecture
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Verification Providers (Payment-First Architecture)
# ID Verification Provider (Veriff)
VERIFF_API_KEY=your_veriff_api_key_here
VERIFF_API_SECRET=your_veriff_api_secret_here
VERIFF_BASE_URL=https://stationapi.veriff.com
ID_PROVIDER=veriff

# Background Check Provider (Certn)
CERTN_API_KEY=your_certn_api_key_here
CERTN_BASE_URL=https://api.certn.co/v1
BG_CHECK_PROVIDER=certn

# Verification Settings
VERIFICATION_GRACE_PERIOD_DAYS=7
ADMIN_REVIEW_SLA_HOURS=48

# SMS/Phone Verification (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=safenest-uploads

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Message Encryption (AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your_base64_encryption_key_here_32_bytes

# Admin Configuration
ADMIN_EMAILS=admin@conest.com,support@conest.com

# CORS
CORS_ORIGIN=http://localhost:19006

# Logging
LOG_LEVEL=debug

# Cron Jobs (Payment-First Architecture)
ENABLE_CRON_JOBS=true

# AI Content Moderation (Child Safety - Constitution Principle I)
# Detects predatory patterns in adult-to-adult messages
AI_MODERATION_ENABLED=true
AI_MODERATION_SHADOW_MODE=true  # Set to false to enable actions (start with true)
AI_MODERATION_PRIMARY_PROVIDER=gemini
AI_MODERATION_FALLBACK_PROVIDER=openai

# Gemini API (Primary - cost effective)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
AI_MODERATION_MODEL_GEMINI=gemini-1.5-flash

# OpenAI API (Fallback)
OPENAI_API_KEY=sk-your_openai_api_key_here
AI_MODERATION_MODEL_OPENAI=gpt-4o-mini

# Moderation Thresholds
AI_MODERATION_AUTO_BLOCK_THRESHOLD=0.85  # Confidence level for auto-blocking
AI_MODERATION_FLAG_THRESHOLD=0.5          # Confidence level for flagging

# Worker Configuration
AI_MODERATION_BATCH_SIZE=10
AI_MODERATION_POLL_INTERVAL_MS=5000
AI_MODERATION_MAX_RETRIES=3

# DEPRECATED - Legacy API Keys (kept for backward compatibility)
CHECKR_API_KEY=deprecated_use_certn
JUMIO_API_TOKEN=deprecated_use_veriff
JUMIO_API_SECRET=deprecated_use_veriff
