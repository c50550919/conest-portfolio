# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=safenest
DB_USER=safenest_user
DB_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Configuration (Test Mode) - Payment-First Architecture
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Verification Providers (Payment-First Architecture)
# ID Verification Provider (Veriff)
VERIFF_API_KEY=your_veriff_api_key_here
VERIFF_BASE_URL=https://stationapi.veriff.com
ID_PROVIDER=veriff

# Background Check Provider (Certn)
CERTN_API_KEY=your_certn_api_key_here
CERTN_BASE_URL=https://api.certn.co/v1
BG_CHECK_PROVIDER=certn

# SMS/Phone Verification (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=safenest-uploads

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:19006

# Logging
LOG_LEVEL=debug

# Cron Jobs (Payment-First Architecture)
ENABLE_CRON_JOBS=true

# DEPRECATED - Legacy API Keys (kept for backward compatibility)
CHECKR_API_KEY=deprecated_use_certn
JUMIO_API_TOKEN=deprecated_use_veriff
JUMIO_API_SECRET=deprecated_use_veriff
