{
  "name": "conest-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "TS_NODE_TRANSPILE_ONLY=true nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "demo": "TS_NODE_TRANSPILE_ONLY=true dotenv -e .env.demo -- nodemon --exec ts-node src/server.ts",
    "demo:start": "dotenv -e .env.demo -- node dist/server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:demo": "dotenv -e .env.demo -- knex migrate:latest",
    "migrate:demo:rollback": "dotenv -e .env.demo -- knex migrate:rollback",
    "seed:dev": "knex seed:run",
    "seed:demo": "dotenv -e .env.demo -- ts-node scripts/seed-demo-presentation.ts",
    "seed:placd-demo": "ts-node scripts/seed-placd-demo.ts",
    "seed:demo:discovery": "dotenv -e .env.demo -- ts-node scripts/seed-demo-presentation.ts --discovery-only",
    "seed:demo:household": "dotenv -e .env.demo -- ts-node scripts/seed-demo-presentation.ts --with-household",
    "demo:reset": "npm run migrate:demo:rollback -- --all && npm run migrate:demo && npm run seed:demo",
    "test": "NODE_ENV=test jest --selectProjects unit",
    "test:watch": "NODE_ENV=test jest --selectProjects unit --watch",
    "test:coverage": "NODE_ENV=test jest --selectProjects unit --coverage",
    "test:integration": "NODE_ENV=test jest --selectProjects integration --runInBand",
    "test:all": "NODE_ENV=test jest --runInBand",
    "test:security": "jest tests/security",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "security:audit": "npm audit && snyk test",
    "complexity": "eslint . --ext .ts --max-warnings 0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@aws-sdk/s3-request-presigner": "^3.967.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.35.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "apple-signin-auth": "^1.7.9",
    "bcrypt": "^6.0.0",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.7.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^133.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "objection": "^3.1.5",
    "pg": "^8.11.3",
    "socket.io": "^4.6.0",
    "stripe": "^14.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.19.0",
    "typescript": "^5.2.0",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "overrides": {
    "lodash": "4.17.23"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.11.7",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "artillery": "^2.0.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1"
  }
}
