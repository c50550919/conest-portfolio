# CoNest/SafeNest - Single Parent Housing Platform
# .gitignore - Security-first configuration

# ============================================================================
# CRITICAL SECURITY - NEVER COMMIT THESE
# ============================================================================
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
*.p12
*.pfx
id_rsa*
*.crt
config/secrets/
secrets/

# API Keys and Credentials
**/credentials.json
**/serviceAccount.json
stripe_keys.txt
aws_credentials

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# Backend
# ============================================================================
backend/node_modules/
backend/dist/
backend/build/
backend/.env*
backend/uploads/
backend/logs/
backend/*.log
backend/coverage/

# Database
postgres_data/
*.sqlite
*.db

# ============================================================================
# Mobile (React Native)
# ============================================================================
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/build/
mobile/coverage/

# iOS
mobile/ios/Pods/
mobile/ios/build/
mobile/ios/*.xcworkspace/xcuserdata/
mobile/ios/*.xcodeproj/xcuserdata/
mobile/ios/DerivedData/

# Android
mobile/android/.gradle/
mobile/android/build/
mobile/android/app/build/
mobile/android/local.properties
mobile/android/*.keystore

# ============================================================================
# Testing
# ============================================================================
coverage/
test-results/

# ============================================================================
# IDE & Editors
# ============================================================================
.vscode/
.idea/
*.swp
.DS_Store

# Ignore vscode AI rules
.github/instructions/codacy.instructions.md

# ============================================================================
# Spec Kit (AI Agent Security)
# ============================================================================
.claude/settings.local.json
.claude/**/*.local.*
.claude/**/credentials/
.claude/**/auth/

# ============================================================================
# Logs & Temp
# ============================================================================
logs/
*.log
tmp/
temp/

# ============================================================================
# Build Artifacts
# ============================================================================
dist/
build/
out/

# ============================================================================
# Keep These Files
# ============================================================================
!.gitkeep
!.env.examplemobile/TempProject/

# Detox E2E test artifacts
mobile/artifacts/

# ============================================================================
# Security Reports & Business Documents
# ============================================================================
snyk_report*.json
*.xlsx

# ============================================================================
# Large Media & Presentation Assets
# ============================================================================
mobile/demo-recordings/
pitch-deck/
workspace/
