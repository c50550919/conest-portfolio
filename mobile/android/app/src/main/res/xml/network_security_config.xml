<?xml version="1.0" encoding="utf-8"?>
<!--
  SECURITY: Network Security Configuration
  - Blocks cleartext (HTTP) traffic by default
  - Enforces HTTPS/TLS for all network communication
  - Prevents man-in-the-middle attacks
  - Required for protecting sensitive user data
-->
<network-security-config>
    <!-- Block all cleartext traffic by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust preloaded CAs -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Development only: Allow localhost for testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Apple Silicon Mac: Allow host machine IP for Android emulator networking -->
        <domain includeSubdomains="true">192.168.1.172</domain>
    </domain-config>
</network-security-config>
