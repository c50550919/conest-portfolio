<?xml version="1.0" encoding="utf-8"?>
<!--
  SECURITY: Network Security Configuration
  - Blocks cleartext (HTTP) traffic by default
  - Enforces HTTPS/TLS for all network communication
  - Certificate pinning for production API domain
  - Prevents man-in-the-middle attacks

  IMPORTANT: Before production launch, generate real pin hashes:
    openssl s_client -servername api.conest.app -connect api.conest.app:443 </dev/null 2>/dev/null \
      | openssl x509 -pubkey -noout \
      | openssl pkey -pubin -outform DER \
      | openssl dgst -sha256 -binary \
      | openssl enc -base64
  Run for each certificate in the chain (leaf + intermediate).
  Always include a backup pin from a different CA for key rotation.
-->
<network-security-config>
    <!-- Block all cleartext traffic by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Production: Certificate pinning for API domain -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">conest.app</domain>
        <pin-set expiration="2027-01-01">
            <!--
              REQUIRED: Replace these placeholder pins before production build.
              Pin 1: Leaf certificate SPKI hash (your server cert)
              Pin 2: Intermediate CA SPKI hash (e.g., Let's Encrypt R3)
              Pin 3: Backup pin from different CA (rotation safety)

              Generate with:
                openssl s_client -servername api.conest.app -connect api.conest.app:443 -showcerts
              Then for each cert in chain:
                openssl x509 -pubkey -noout | openssl pkey -pubin -outform DER | openssl dgst -sha256 -binary | openssl enc -base64
            -->
            <pin digest="SHA-256">REPLACE_WITH_LEAF_CERT_SPKI_HASH=</pin>
            <pin digest="SHA-256">REPLACE_WITH_INTERMEDIATE_CA_SPKI_HASH=</pin>
            <!-- Backup pin: Use a different CA's intermediate for rotation safety -->
            <pin digest="SHA-256">REPLACE_WITH_BACKUP_CA_SPKI_HASH=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Development only: Allow localhost for testing (no pinning) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">192.168.1.172</domain>
    </domain-config>
</network-security-config>
