{
  "name": "conest-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "CoNest - Single Parent Housing Platform (Monorepo Root)",
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint:backend && npm run lint:mobile",
    "lint:backend": "cd backend && npm run lint",
    "lint:mobile": "cd mobile && npm run lint",
    "lint:fix": "npm run lint:fix:backend && npm run lint:fix:mobile",
    "lint:fix:backend": "cd backend && npm run lint -- --fix",
    "lint:fix:mobile": "cd mobile && npm run lint -- --fix"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "backend/**/*.{ts,tsx}": [
      "cd backend && npx eslint --fix --max-warnings=0"
    ],
    "mobile/**/*.{ts,tsx,js,jsx}": [
      "cd mobile && npx eslint --fix --max-warnings=0"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "docx": "^9.5.1"
  }
}
